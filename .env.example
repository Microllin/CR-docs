# ---- 本地开发（pnpm dev）----
# 指向本机 Postgres
DATABASE_URL=postgres://payload:payload@localhost:5432/crdocs

# ---- Docker Compose 部署会用到的变量（写在 .env 里，compose 自动读取）----
# 数据库凭据（compose 里的 db 服务与 DATABASE_URL 都会用到）
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=crdocs
# 对外暴露端口
WEB_PORT=3000

# Payload 密钥：务必改成随机长字符串（可用 `openssl rand -hex 32` 生成）
PAYLOAD_SECRET=YOUR_SECRET_HERE

# 种子脚本创建的初始管理员（scripts/seed.ts 读取；登录后请立即改密码）
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
